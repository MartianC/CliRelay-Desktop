{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "shell",
  "description": "Shell 和 Status 窗口可调用 Desktop 命令，并只使用受限的核心窗口能力。",
  "windows": ["main", "status"],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-hide",
    "dialog:allow-open",
    "autostart:allow-is-enabled"
  ]
}
